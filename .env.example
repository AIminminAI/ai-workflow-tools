# AI API Key - 让 AI Match Wizard 使用真实 AI 推荐
#
# 默认使用硅基流动 SiliconFlow（注册即送 14 元免费额度，可调用 DeepSeek-V3）
# 注册地址：https://cloud.siliconflow.cn → 注册 → 控制台 → API 密钥 → 新建
#
# 充值用户也可切回 DeepSeek 官方 API（需另配置 AI_API_URL 和 AI_MODEL）
AI_API_KEY=your_siliconflow_api_key_here

# 可选：切换到 DeepSeek 官方 API（需充值）
# AI_API_URL=https://api.deepseek.com/v1/chat/completions
# AI_MODEL=deepseek-chat

# 兼容旧变量名（不推荐使用，仅向后兼容）
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
